# Per-instrument config for the trader-sol container.
#
# Copy this file to `.env.sol` on the deploy host and fill in your picks.
# `.env.sol` is gitignored — values stay local to the host.
#
# Variables here shadow corresponding values in the base `.env` for the
# `trader-sol` container only. Other containers (trader-eth, trader-btc)
# are unaffected.
#
# Required (compose fails fast if missing or unset):
STRATEGY=
INSTRUMENT_ID=
BAR_INTERVAL=
STOP_PCT=

# MA crossover params (required if STRATEGY is in the MACross family).
# Other strategies have their own env vars — see src/config/settings.py.
MA_FAST=
MA_SLOW=
MA_TYPE=
