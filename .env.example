# Database
DATABASE_URL=postgresql+asyncpg://nautilus:nautilus_dev@localhost:5434/nautilus_platform
POSTGRES_PASSWORD=nautilus_dev
POSTGRES_PORT=5434

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# NautilusTrader
NT_LOG_LEVEL=INFO  # Set to ERROR in Jupyter notebooks
PARQUET_CATALOG_PATH=./data/catalog

# Telegram — leave empty to disable alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Hyperliquid
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=
HL_TESTNET=true

# Trading
TRADER_ID=TRADER-001
STRATEGY=EMACross              # EMACross | SMACross | EMACrossATR | MACDRSI
INSTRUMENT_ID=BTC-USD-PERP.HYPERLIQUID  # BTC | ETH | SOL
BAR_INTERVAL=1-HOUR-LAST-EXTERNAL       # 1-MINUTE | 5-MINUTE | 15-MINUTE | 1-HOUR | 4-HOUR | 1-DAY
TRADE_SIZE=0.001               # BTC ~0.001, ETH ~0.01, SOL ~0.1 (~$50-100 notional)
STARTING_BALANCE=10000

# Grafana
GRAFANA_PASSWORD=changeme
