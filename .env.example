# Database
POSTGRES_DB=nautilus_platform
POSTGRES_USER=nautilus
POSTGRES_PASSWORD=nautilus_dev
POSTGRES_PORT=5434

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram — leave empty to disable alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Hyperliquid
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=
HL_TESTNET=true
# Live trading confirmation — required for containerized live trading
# Set to 'yes' to bypass the interactive prompt in run_live.py
# LIVE_CONFIRM=yes

# Trading script — which runner the Docker container executes
# scripts/run_sandbox.py  (paper trading, default)
# scripts/run_live.py     (live trading — also set HL_TESTNET=false and LIVE_CONFIRM=yes)
TRADING_SCRIPT=scripts/run_sandbox.py

# ── Trader identity ─────────────────────────────────────────────────
TRADER_ID=TRADER-001

# ── Account / sizing — SAME values flow backtest -> sandbox -> live ──
# Defaults: $1k seed, $2k position, 20x lev, 5% stop = isolated-margin
# equivalence (worst-case loss per trade = initial margin = $100).
STARTING_CAPITAL=1000
TRADE_NOTIONAL=2000
LEVERAGE=20
STOP_PCT=0.05

# ── Default venue + data ────────────────────────────────────────────
DATA_SOURCE=BINANCE_PERP
EXEC_VENUE=HYPERLIQUID_PERP

# ── Strategy + interval (sandbox/live picks; backtest notebooks override) ──
STRATEGY=MACross               # MACross | …Cross | MACrossLongOnly | …CrossLongOnly | MACrossATR | MACDRSI
INSTRUMENT_ID=BTC-USD-PERP.HYPERLIQUID  # BTC | ETH | SOL
BAR_INTERVAL=4h                # 1m | 5m | 15m | 1h | 4h | 1d  (friendly format)

# ── Strategy hyperparameters — sandbox/live runners read these ──────
# Backtest notebooks pick their own (one notebook per strategy).
# Only the params for STRATEGY above actually apply at runtime; the
# rest stay at defaults until you switch.
#
# MA crossover family (MACross, *Cross, MACrossLongOnly, *CrossLongOnly)
MA_FAST=10
MA_SLOW=100
MA_TYPE=EMA                    # EMA | SMA | HMA | DEMA | AMA | VIDYA

# Treat the first observed signal on deploy as a synthetic cross so the
# strategy enters immediately instead of waiting weeks for a real
# transition. Set `true` for live mid-trend deploys; leave `false` for
# Phase 2.5/2.6 verification (synthetic bootstrap muddles backtest-vs-
# paper signal alignment). See docs/STRATEGY_ENTRY_RULES.md.
BOOTSTRAP_ON_DEPLOY=false

# Other strategies (MACrossATR, MACDRSI, etc.) have env vars too — see
# `src/config/settings.py` for the field names and defaults. Add them
# here only when actually switching strategies.

# ── Liquidation simulator (research only; live ignores) ─────────────
LIQUIDATION_ENABLED=true
LIQUIDATION_MIN_TRADE_NOTIONAL=10

# ── Default test universe (batch runner + research notebooks) ───────
# JSON-array form (pydantic parses comma-separated lists this way).
DEFAULT_ASSETS=["BTC","ETH","SOL"]
DEFAULT_INTERVALS=["4h","1d"]

# Grafana
GRAFANA_PASSWORD=changeme
GRAFANA_RO_PASSWORD=changeme
