# Database
POSTGRES_DB=nautilus_platform
POSTGRES_USER=nautilus
POSTGRES_PASSWORD=nautilus_dev
POSTGRES_PORT=5434

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram — leave empty to disable alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Hyperliquid
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=
HL_TESTNET=true
# Live trading confirmation — required for containerized live trading
# Set to 'yes' to bypass the interactive prompt in run_live.py
# LIVE_CONFIRM=yes

# Trading script — which runner the Docker container executes
# scripts/run_sandbox.py  (paper trading, default)
# scripts/run_live.py     (live trading — also set HL_TESTNET=false and LIVE_CONFIRM=yes)
TRADING_SCRIPT=scripts/run_sandbox.py

# Trading
TRADER_ID=TRADER-001
STRATEGY=MACross               # MACross | …Cross | MACrossLongOnly | …CrossLongOnly | MACrossATR | MACDRSI
INSTRUMENT_ID=BTC-USD-PERP.HYPERLIQUID  # BTC | ETH | SOL
BAR_INTERVAL=1-HOUR-LAST-EXTERNAL       # 1-MINUTE | 5-MINUTE | 15-MINUTE | 1-HOUR | 4-HOUR | 1-DAY
TRADE_NOTIONAL=100             # USD notional per trade (all strategies)
STARTING_BALANCE=1000

# Grafana
GRAFANA_PASSWORD=changeme
GRAFANA_RO_PASSWORD=changeme
